# Copy to .env.local for development. On Vercel, set these in
# Project Settings → Environment Variables (Production + Preview).

# ── Supabase ─────────────────────────────────────────────────────────
# Public — safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by /admin and seeding scripts. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin dashboard (/admin) ─────────────────────────────────────────
# The single password that unlocks the admin UI.
ADMIN_PASSWORD=
# 32-byte random hex used to sign the admin session cookie.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ── Google Maps (centres map on /business-centers) ───────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional — Map ID for advanced styling / advanced markers.
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
