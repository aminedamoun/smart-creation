# Copy to .env.local for development. On Vercel, set these in
# Project Settings → Environment Variables.

# 32-byte random hex (generate with: openssl rand -hex 32)
PAYLOAD_SECRET=

# Local dev: file:./payload.db (SQLite, no setup needed)
# Production: a Postgres URL — switch the adapter in payload.config.ts
#             from sqliteAdapter to postgresAdapter when deploying.
DATABASE_URI=file:./payload.db

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Vercel Blob (optional — used in production for media uploads)
# BLOB_READ_WRITE_TOKEN=
