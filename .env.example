# Copy to .env.local for development. On Vercel, set these in
# Project Settings → Environment Variables (Production + Preview).

# ── Supabase ─────────────────────────────────────────────────────────
# Public — safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used by /admin and seeding scripts. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin dashboard (/admin) ─────────────────────────────────────────
# The single password that unlocks the admin UI.
ADMIN_PASSWORD=
# 32-byte random hex used to sign the admin session cookie.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ── Google Maps (centres map on /business-centers) ───────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional — Map ID for advanced styling / advanced markers.
# NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# ── Email (contact form + newsletter signups) ────────────────────────
# Direct SMTP — no third-party service. Use the credentials of the inbox
# you own at admin@thesmartcreation.com (or any mailbox on your domain).
#
# Common providers:
#   Hostinger     SMTP_HOST=smtp.hostinger.com   SMTP_PORT=465  SMTP_SECURE=true
#   cPanel/Plesk  SMTP_HOST=mail.thesmartcreation.com  SMTP_PORT=465  SMTP_SECURE=true
#   Google W.S.   SMTP_HOST=smtp.gmail.com       SMTP_PORT=465  SMTP_SECURE=true (app password)
#   Microsoft 365 SMTP_HOST=smtp.office365.com   SMTP_PORT=587  SMTP_SECURE=false
#   Zoho          SMTP_HOST=smtp.zoho.com        SMTP_PORT=465  SMTP_SECURE=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=admin@thesmartcreation.com
SMTP_PASS=
# Override only if your SMTP server needs STARTTLS on a non-default port.
# SMTP_SECURE=true
# Sender shown in the "From" header — must match SMTP_USER on most servers.
SMTP_FROM_EMAIL="Smart Creation Group <admin@thesmartcreation.com>"
# Inbox that receives every form submission.
ADMIN_EMAIL=admin@thesmartcreation.com
